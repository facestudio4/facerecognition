APP_ENV=production
APP_NAME=FaceRecognitionStudio
API_HOST=0.0.0.0
API_PORT=8787
SQLITE_PATH=/var/data/facestudio.db

FACE_STUDIO_MOBILE_LATEST_VERSION=0.1.0+11
FACE_STUDIO_MOBILE_MIN_VERSION=0.1.0+10
FACE_STUDIO_MOBILE_APK_URL=https://github.com/<your-org>/<your-repo>/releases/latest
FACE_STUDIO_MOBILE_UPDATE_NOTES=A new version is available with performance and stability improvements.
FACE_STUDIO_MOBILE_FORCE_UPDATE=false

MOBILE_RECOGNITION_THRESHOLD=0.48
MOBILE_RECOGNITION_MARGIN=0.03

FACESTUDIO_SIGNUP_ALLOW_SMTP_FALLBACK=1
FACESTUDIO_SMTP_HOST=smtp.gmail.com
FACESTUDIO_SMTP_USER=your-email@gmail.com
FACESTUDIO_SMTP_APP_PASSWORD=your-app-password
FACESTUDIO_SMTP_FROM=your-email@gmail.com
FACESTUDIO_SMTP_PORT=587
FACESTUDIO_SMTP_TLS=1
FACESTUDIO_SMTP_SSL=0
FACESTUDIO_SMTP_TIMEOUT=10
FACESTUDIO_SMTP_TOTAL_TIMEOUT=9
